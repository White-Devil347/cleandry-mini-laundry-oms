{
  "info": {
    "name": "CleanDry API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "host": ["{{baseUrl}}"],
          "path": ["api", "health"]
        }
      }
    },
    {
      "name": "Create Order",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerName\": \"Aarav Sharma\",\n  \"phoneNumber\": \"9876543210\",\n  \"items\": [\n    {\n      \"garmentType\": \"Shirt\",\n      \"quantity\": 3\n    },\n    {\n      \"garmentType\": \"Pants\",\n      \"quantity\": 2\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/orders",
          "host": ["{{baseUrl}}"],
          "path": ["api", "orders"]
        }
      }
    },
    {
      "name": "List Orders",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/orders",
          "host": ["{{baseUrl}}"],
          "path": ["api", "orders"]
        }
      }
    },
    {
      "name": "Filter Orders by Status",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/orders?status=READY",
          "host": ["{{baseUrl}}"],
          "path": ["api", "orders"],
          "query": [
            {
              "key": "status",
              "value": "READY"
            }
          ]
        }
      }
    },
    {
      "name": "Search Orders",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/orders?search=9876",
          "host": ["{{baseUrl}}"],
          "path": ["api", "orders"],
          "query": [
            {
              "key": "search",
              "value": "9876"
            }
          ]
        }
      }
    },
    {
      "name": "Update Order Status",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"PROCESSING\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/orders/ORD-20260427-0001/status",
          "host": ["{{baseUrl}}"],
          "path": ["api", "orders", "ORD-20260427-0001", "status"]
        }
      }
    },
    {
      "name": "Dashboard",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/dashboard",
          "host": ["{{baseUrl}}"],
          "path": ["api", "dashboard"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ]
}
